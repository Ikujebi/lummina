generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================
enum Role {
  ADMIN
  LAWYER
  CLIENT
}

enum MatterStatus {
  OPEN
  IN_PROGRESS
  PENDING
  CLOSED
}

enum DocumentStatus {
  DRAFT
  FINAL
  SIGNED
}

enum NotificationType {
  INFO
  WARNING
  DEADLINE
  MESSAGE
}

// ============================================
// MODELS
// ============================================

model User {
  id             String   @id @default(uuid())
  name           String?
  email          String   @unique
  password       String
  role           Role
  twoFactor      Boolean  @default(false)
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  clients             Client[]
  sessions            Session[]
  invitations         Invitation[]
  passwordResets      PasswordReset[]
  twoFactorTokens     TwoFactorToken[]
  mattersAsLawyer     Matter[]
  documents           Document[]
  signatures          Signature[]
  messagesSent        Message[]
  appointmentsCreated Appointment[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  timeEntries         TimeEntry[]

  @@map("User")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      Role
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("Invitation")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  matters Matter[]

  @@map("Client")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("Session")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("PasswordReset")
}

model TwoFactorToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("TwoFactorToken")
}

model Matter {
  id          String       @id @default(uuid())
  caseNumber  String   @unique
  title       String
  description String?
  status      MatterStatus
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  lawyerId    String
  lawyer      User         @relation(fields: [lawyerId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())

  activities   MatterActivity[]
  documents    Document[]
  tasks        Task[]
  keyDates     KeyDate[]
  messages     Message[]
  appointments Appointment[]
  timeEntries  TimeEntry[]

  @@index([clientId])
  @@index([lawyerId])
  @@map("Matter")
}

model MatterActivity {
  id        String   @id @default(uuid())
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([matterId])
  @@map("MatterActivity")
}

model Document {
  id         String         @id @default(uuid())
  name       String
  fileUrl    String
  status     DocumentStatus
  matterId   String
  matter     Matter         @relation(fields: [matterId], references: [id])
  uploadedBy String
  uploader   User           @relation(fields: [uploadedBy], references: [id])
  folderPath String?
  previewUrl String?
  externalId String?
  createdAt  DateTime       @default(now())

  versions   DocumentVersion[]
  signatures Signature[]

  @@index([matterId])
  @@map("Document")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  fileUrl    String
  version    Int
  createdAt  DateTime @default(now())

  @@index([documentId])
  @@map("DocumentVersion")
}

model Signature {
  id         String    @id @default(uuid())
  documentId String
  document   Document  @relation(fields: [documentId], references: [id])
  signedBy   String
  user       User      @relation(fields: [signedBy], references: [id])
  signedAt   DateTime?
  provider   String

  @@index([documentId])
  @@map("Signature")
}

model Task {
  id        String    @id @default(uuid())
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  matterId  String
  matter    Matter    @relation(fields: [matterId], references: [id])

  @@index([matterId])
  @@map("Task")
}

model KeyDate {
  id       String   @id @default(uuid())
  title    String
  date     DateTime
  matterId String
  matter   Matter   @relation(fields: [matterId], references: [id])

  @@index([matterId])
  @@map("KeyDate")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id])
  createdAt DateTime @default(now())
  archived  Boolean  @default(false)

  attachments MessageAttachment[]

  @@index([senderId])
  @@index([matterId])
  @@map("Message")
}

model MessageAttachment {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id])
  fileUrl   String

  @@index([messageId])
  @@map("MessageAttachment")
}

model Appointment {
  id                 String   @id @default(uuid())
  title              String
  startTime          DateTime
  endTime            DateTime
  matterId           String
  matter             Matter   @relation(fields: [matterId], references: [id])
  createdBy          String
  creator            User     @relation(fields: [createdBy], references: [id])
  externalCalendarId String?
  videoLink          String?

  @@index([matterId])
  @@index([createdBy])
  @@map("Appointment")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("Notification")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("AuditLog")
}

model TimeEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id])
  hours     Float
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([matterId])
  @@map("TimeEntry")
}

model EmailLog {
  id        String   @id @default(uuid())
  recipient String
  subject   String
  body      String
  sentAt    DateTime @default(now())
  status    String

  @@map("EmailLog")
}

model GlossaryCategory {
  id    String         @id @default(uuid())
  name  String
  terms GlossaryTerm[]

  @@map("GlossaryCategory")
}

model GlossaryTerm {
  id         String           @id @default(uuid())
  term       String
  definition String
  categoryId String
  category   GlossaryCategory @relation(fields: [categoryId], references: [id])

  @@map("GlossaryTerm")
}
