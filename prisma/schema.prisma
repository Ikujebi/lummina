

-- ============================================
-- ENUMS
-- ============================================

CREATE TYPE "Role" AS ENUM ('ADMIN', 'LAWYER', 'CLIENT');
CREATE TYPE "MatterStatus" AS ENUM ('OPEN', 'IN_PROGRESS', 'PENDING', 'CLOSED');
CREATE TYPE "DocumentStatus" AS ENUM ('DRAFT', 'FINAL', 'SIGNED');
CREATE TYPE "NotificationType" AS ENUM ('INFO', 'WARNING', 'DEADLINE', 'MESSAGE');

-- ============================================
-- TABLES
-- ============================================

CREATE TABLE "User" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT,
    email TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role "Role" NOT NULL,
    "twoFactor" BOOLEAN DEFAULT FALSE,
    "profilePicture" TEXT, 
    "createdAt" TIMESTAMPTZ DEFAULT NOW(),
    "updatedAt" TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE "Client" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    email TEXT UNIQUE,
    phone TEXT,
    address TEXT,
    "createdAt" TIMESTAMPTZ DEFAULT NOW(),
    "userId" UUID NOT NULL REFERENCES "User"(id)
);

CREATE TABLE "Session" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    "expiresAt" TIMESTAMPTZ NOT NULL,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE "Invitation" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email TEXT NOT NULL,
    role "Role" NOT NULL,
    token TEXT UNIQUE NOT NULL,
    "expiresAt" TIMESTAMPTZ NOT NULL,
    accepted BOOLEAN DEFAULT FALSE,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE "PasswordReset" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    token TEXT UNIQUE NOT NULL,
    "expiresAt" TIMESTAMPTZ NOT NULL,
    used BOOLEAN DEFAULT FALSE,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "PasswordReset_userId_index" ON "PasswordReset" ("userId");

CREATE TABLE "TwoFactorToken" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    code TEXT NOT NULL,
    "expiresAt" TIMESTAMPTZ NOT NULL,
    used BOOLEAN DEFAULT FALSE,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "TwoFactorToken_userId_index" ON "TwoFactorToken" ("userId");

CREATE TABLE "Matter" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title TEXT NOT NULL,
    description TEXT,
    status "MatterStatus" NOT NULL,
    "clientId" UUID NOT NULL REFERENCES "Client"(id),
    "lawyerId" UUID NOT NULL REFERENCES "User"(id),
    "createdAt" TIMESTAMPTZ DEFAULT NOW(),
    "updatedAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "Matter_clientId_index" ON "Matter" ("clientId");
CREATE INDEX "Matter_lawyerId_index" ON "Matter" ("lawyerId");

CREATE TABLE "MatterActivity" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "matterId" UUID NOT NULL REFERENCES "Matter"(id),
    action TEXT NOT NULL,
    details TEXT,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "MatterActivity_matterId_index" ON "MatterActivity" ("matterId");

CREATE TABLE "Document" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    "fileUrl" TEXT NOT NULL,
    status "DocumentStatus" NOT NULL,
    "matterId" UUID NOT NULL REFERENCES "Matter"(id),
    "uploadedBy" UUID NOT NULL REFERENCES "User"(id),
    "folderPath" TEXT,
    "previewUrl" TEXT,
    "externalId" TEXT,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "Document_matterId_index" ON "Document" ("matterId");

CREATE TABLE "DocumentVersion" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "documentId" UUID NOT NULL REFERENCES "Document"(id),
    "fileUrl" TEXT NOT NULL,
    version INT NOT NULL,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "DocumentVersion_documentId_index" ON "DocumentVersion" ("documentId");

CREATE TABLE "Signature" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "documentId" UUID NOT NULL REFERENCES "Document"(id),
    "signedBy" UUID NOT NULL REFERENCES "User"(id),
    "signedAt" TIMESTAMPTZ,
    provider TEXT NOT NULL
);
CREATE INDEX "Signature_documentId_index" ON "Signature" ("documentId");

CREATE TABLE "Task" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title TEXT NOT NULL,
    completed BOOLEAN DEFAULT FALSE,
    "dueDate" TIMESTAMPTZ,
    "matterId" UUID NOT NULL REFERENCES "Matter"(id)
);
CREATE INDEX "Task_matterId_index" ON "Task" ("matterId");

CREATE TABLE "KeyDate" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title TEXT NOT NULL,
    date TIMESTAMPTZ NOT NULL,
    "matterId" UUID NOT NULL REFERENCES "Matter"(id)
);
CREATE INDEX "KeyDate_matterId_index" ON "KeyDate" ("matterId");

CREATE TABLE "Message" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    content TEXT NOT NULL,
    "senderId" UUID NOT NULL REFERENCES "User"(id),
    "matterId" UUID NOT NULL REFERENCES "Matter"(id),
    "createdAt" TIMESTAMPTZ DEFAULT NOW(),
    archived BOOLEAN DEFAULT FALSE
);
CREATE INDEX "Message_senderId_index" ON "Message" ("senderId");
CREATE INDEX "Message_matterId_index" ON "Message" ("matterId");

CREATE TABLE "MessageAttachment" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "messageId" UUID NOT NULL REFERENCES "Message"(id),
    "fileUrl" TEXT NOT NULL
);
CREATE INDEX "MessageAttachment_messageId_index" ON "MessageAttachment" ("messageId");

CREATE TABLE "Appointment" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title TEXT NOT NULL,
    "startTime" TIMESTAMPTZ NOT NULL,
    "endTime" TIMESTAMPTZ NOT NULL,
    "matterId" UUID NOT NULL REFERENCES "Matter"(id),
    "createdBy" UUID NOT NULL REFERENCES "User"(id),
    "externalCalendarId" TEXT,
    "videoLink" TEXT
);
CREATE INDEX "Appointment_matterId_index" ON "Appointment" ("matterId");
CREATE INDEX "Appointment_createdBy_index" ON "Appointment" ("createdBy");

CREATE TABLE "Notification" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    title TEXT NOT NULL,
    message TEXT NOT NULL,
    type "NotificationType" NOT NULL,
    read BOOLEAN DEFAULT FALSE,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "Notification_userId_index" ON "Notification" ("userId");

CREATE TABLE "AuditLog" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    action TEXT NOT NULL,
    entity TEXT,
    "entityId" UUID,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "AuditLog_userId_index" ON "AuditLog" ("userId");

CREATE TABLE "TimeEntry" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    "userId" UUID NOT NULL REFERENCES "User"(id),
    "matterId" UUID NOT NULL REFERENCES "Matter"(id),
    hours FLOAT NOT NULL,
    note TEXT,
    "createdAt" TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX "TimeEntry_userId_index" ON "TimeEntry" ("userId");
CREATE INDEX "TimeEntry_matterId_index" ON "TimeEntry" ("matterId");

CREATE TABLE "EmailLog" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    recipient TEXT NOT NULL,
    subject TEXT NOT NULL,
    body TEXT NOT NULL,
    "sentAt" TIMESTAMPTZ DEFAULT NOW(),
    status TEXT NOT NULL
);

CREATE TABLE "GlossaryCategory" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL
);

CREATE TABLE "GlossaryTerm" (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    term TEXT NOT NULL,
    definition TEXT NOT NULL,
    "categoryId" UUID NOT NULL REFERENCES "GlossaryCategory"(id)
);

-- ============================================
-- UPDATED AT TRIGGER
-- ============================================

CREATE OR REPLACE FUNCTION update_updatedat_column()
RETURNS TRIGGER AS $$
BEGIN
  NEW."updatedAt" = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER user_updatedat_trigger
BEFORE UPDATE ON "User"
FOR EACH ROW
EXECUTE FUNCTION update_updatedat_column();

CREATE TRIGGER matter_updatedat_trigger
BEFORE UPDATE ON "Matter"
FOR EACH ROW
EXECUTE FUNCTION update_updatedat_column();